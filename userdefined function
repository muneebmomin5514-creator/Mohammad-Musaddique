def largeststr(s1,s2,s3,s4,s5):
    mystr={s1:len(s1),s2:len(s2),s3:len(s3),s4:len(s4),s5:len(s5)}
    maximum=max(list(mystr.values()))
    for m in mystr.items():
        if m[1]>=maximum:
